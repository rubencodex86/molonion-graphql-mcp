# Copia para .env e preenche com os teus valores.
# O .env tem segredos e está no .gitignore — nunca o commites.

# Endpoint GraphQL da Moloni ON (normalmente não precisa de mudar)
MOLONION_API_URL=https://api.molonion.pt/v1

# API Key de serviço (máquina-a-máquina): Conta → API → separador "API Keys".
# É enviada no header Authorization: Bearer <key>.
MOLONION_API_KEY=

# Opcional: empresa por omissão para operações que pedem companyId.
# Descobre os IDs com a tool `me` (devolve userCompanies { companyId name }).
MOLONION_COMPANY_ID=